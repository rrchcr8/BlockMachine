<Window x:Class="BlockMachine.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Block Machine - Configuración"
        Height="780"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Block Machine"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1"
                       Text="Configura el horario, los mensajes y cómo se muestran."
                       Foreground="#666"
                       Margin="0,0,0,20"/>

            <GroupBox Grid.Row="2" Header="Horario de bloqueo" Padding="12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Desde (HH:mm)" Margin="0,0,0,4"/>
                        <TextBox x:Name="StartTimeBox" Height="32"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hasta (HH:mm)" Margin="0,0,0,4"/>
                        <TextBox x:Name="EndTimeBox" Height="32"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="3" Header="Modo de visualización" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <RadioButton x:Name="SingleModeRadio"
                                 GroupName="DisplayMode"
                                 Content="Un solo mensaje (muestra el primero seleccionado)"
                                 Margin="0,0,0,8"
                                 Checked="DisplayMode_Changed"/>
                    <RadioButton x:Name="SlideshowModeRadio"
                                 GroupName="DisplayMode"
                                 Content="Presentación: rotar mensajes seleccionados"
                                 Margin="0,0,0,12"
                                 Checked="DisplayMode_Changed"/>
                    <StackPanel x:Name="SlideIntervalPanel" Orientation="Horizontal">
                        <TextBlock Text="Segundos entre mensajes:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="SlideIntervalBox"
                                 Width="64"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 Text="30"/>
                        <TextBlock Text="(mín. 5, máx. 600)"
                                   VerticalAlignment="Center"
                                   Foreground="#888"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="4" Header="Mensajes" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Marca cuáles quieres mostrar. Puedes tener varios y elegir cuáles activar."
                               TextWrapping="Wrap"
                               Foreground="#666"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Variables: {hora} = hora actual, {fecha} = fecha en español"
                               Foreground="#888"
                               FontSize="12"
                               Margin="0,0,0,8"/>
                </StackPanel>
            </GroupBox>

            <ItemsControl x:Name="MessagesPanel"
                          Grid.Row="5"
                          Margin="0,0,0,8"/>

            <Button Grid.Row="6"
                    Content="+ Agregar mensaje"
                    Height="32"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16"
                    Click="AddMessage_Click"/>

            <GroupBox Grid.Row="7" Header="Contraseña de administrador" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Nueva contraseña (dejar vacío para no cambiar)"
                               Margin="0,0,0,4"/>
                    <PasswordBox x:Name="NewPasswordBox" Height="32" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Height="32"/>
                </StackPanel>
            </GroupBox>

            <StackPanel Grid.Row="8" Margin="0,0,0,16">
                <CheckBox x:Name="EnabledCheckBox"
                          Content="Bloqueo activo"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="StartupCheckBox"
                          Content="Iniciar con Windows"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="DesktopShortcutCheckBox"
                          Content="Acceso directo en escritorio (Block Machine - Administración)"/>
            </StackPanel>

            <TextBlock x:Name="StatusText"
                       Grid.Row="9"
                       Foreground="#C0392B"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <StackPanel Grid.Row="10"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Probar bloqueo"
                        Width="120"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="TestBlock_Click"/>
                <Button Content="Guardar"
                        Width="100"
                        Height="34"
                        IsDefault="True"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
