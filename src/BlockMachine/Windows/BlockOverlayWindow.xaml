<Window x:Class="BlockMachine.Windows.BlockOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#1A2744"
        KeyDown="Window_OnKeyDown"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="ContentPanel"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    MaxWidth="900"
                    Margin="40"
                    Opacity="1">
            <TextBlock x:Name="TitleText"
                       Text="Es hora de descansar"
                       Foreground="White"
                       FontSize="42"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,24"/>

            <TextBlock x:Name="MessageText"
                       Foreground="#E8ECF4"
                       FontSize="28"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       LineHeight="40"
                       Margin="0,0,0,16"/>

            <TextBlock x:Name="SlideIndicator"
                       Foreground="#7A8FBB"
                       FontSize="16"
                       TextAlignment="Center"
                       Margin="0,0,0,16"
                       Visibility="Collapsed"/>

            <TextBlock x:Name="UntilText"
                       Foreground="#A8B4CC"
                       FontSize="18"
                       TextAlignment="Center"
                       Margin="0,0,0,32"/>
        </StackPanel>

        <Button Grid.Row="2"
                Content="Desbloquear (administrador)"
                HorizontalAlignment="Center"
                Padding="24,10"
                FontSize="14"
                Opacity="0.35"
                Background="#2E3F66"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="Unlock_Click"/>
    </Grid>
</Window>
