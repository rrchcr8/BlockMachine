<Window x:Class="BlockMachine.Windows.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contraseña de administrador"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText"
                   Text="Ingresa la contraseña de administrador:"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Margin="0,0,0,12"/>

        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="1"
                     Height="32"
                     FontSize="14"
                     KeyDown="PasswordBox_OnKeyDown"/>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="2"
                   Foreground="#C0392B"
                   Margin="0,8,0,0"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancelar"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="Aceptar"
                    Width="100"
                    Height="32"
                    IsDefault="True"
                    Click="Accept_Click"/>
        </StackPanel>
    </Grid>
</Window>
